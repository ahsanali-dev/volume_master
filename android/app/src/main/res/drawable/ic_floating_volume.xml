<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer glow shadow layer -->
    <item>
        <shape android:shape="oval">
            <solid android:color="#332563EB"/>
            <size android:width="72dp" android:height="72dp"/>
        </shape>
    </item>

    <!-- Main circular gradient background -->
    <item
        android:bottom="4dp"
        android:left="4dp"
        android:right="4dp"
        android:top="4dp">
        <shape android:shape="oval">
            <gradient
                android:angle="135"
                android:centerColor="#3B82F6"
                android:endColor="#1D4ED8"
                android:startColor="#6366F1"
                android:type="linear"/>
            <size android:width="64dp" android:height="64dp"/>
        </shape>
    </item>

</layer-list>
